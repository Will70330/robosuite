<mujoco model="yam">
    <!--
      YAM 6-DOF arm with integrated parallel-jaw gripper.
      Adapted from homer/mj_assets/stanford_tidybot2/tidybot_yam_cube.xml.

      The gripper (left_finger, right_finger) is embedded directly in the arm XML
      because it is a custom design with equality-constrained finger coupling.
      A NullGripper is used at the right_hand mount so no external gripper merges in.

      Joint hierarchy: joint1..joint6 (6-DOF arm) + left_finger/right_finger (gripper).

      All default class attributes are inlined to be compatible with robosuite's
      default expansion system.
    -->
    <compiler angle="radian"/>

    <asset>
        <material name="yam_black" rgba="0.25 0.25 0.25 1"/>
        <material name="yam_white" rgba="0.9 0.9 0.9 1"/>
        <mesh name="yam_model2" file="meshes/model2.stl"/>
        <mesh name="yam_model2__2" file="meshes/model2__2.stl"/>
        <mesh name="yam_model2__3" file="meshes/model2__3.stl"/>
        <mesh name="yam_model2__4" file="meshes/model2__4.stl"/>
        <mesh name="yam_model2__5" file="meshes/model2__5.stl"/>
        <mesh name="yam_model2__6" file="meshes/model2__6.stl"/>
        <mesh name="yam_model2__7" file="meshes/model2__7.stl"/>
        <mesh name="yam_model2__8" file="meshes/model2__8.stl"/>
        <mesh name="yam_model2__9" file="meshes/model2__9.stl"/>
        <mesh name="yam_model2__10" file="meshes/model2__10.stl"/>
        <mesh name="yam_model2__11" file="meshes/model2__11.stl"/>
        <mesh name="yam_model2__12" file="meshes/model2__12.stl"/>
        <mesh name="yam_model2__13" file="meshes/model2__13.stl"/>
        <mesh name="yam_model2__14" file="meshes/model2__14.stl"/>
        <mesh name="yam_model2__15" file="meshes/model2__15.stl"/>
        <mesh name="yam_model2__16" file="meshes/model2__16.stl"/>
        <mesh name="yam_model2__17" file="meshes/model2__17.stl"/>
    </asset>

    <actuator>
        <!-- YAM arm joints as torque actuators (required for OSC controller).
             Torque limits from homer: dm4340 ±28 Nm, dm4310 ±10 Nm. -->
        <motor ctrllimited="true" ctrlrange="-28.0 28.0" joint="joint1" name="torq_j1"/>
        <motor ctrllimited="true" ctrlrange="-28.0 28.0" joint="joint2" name="torq_j2"/>
        <motor ctrllimited="true" ctrlrange="-28.0 28.0" joint="joint3" name="torq_j3"/>
        <motor ctrllimited="true" ctrlrange="-10.0 10.0" joint="joint4" name="torq_j4"/>
        <motor ctrllimited="true" ctrlrange="-10.0 10.0" joint="joint5" name="torq_j5"/>
        <motor ctrllimited="true" ctrlrange="-10.0 10.0" joint="joint6" name="torq_j6"/>
    </actuator>

    <worldbody>
        <body name="base" pos="0 0 0">
            <!-- Robot overview camera -->
            <camera mode="fixed" name="robotview" pos="1.0 0 0.4" quat="0.653 0.271 0.271 0.653"/>
            <inertial pos="0 0 0" mass="0.5" diaginertia="0.001 0.001 0.001"/>

            <body name="arm_base" pos="0 0 0">
                <site name="right_center" pos="0 0 0" size="0.01" rgba="1 0.3 0.3 1" type="sphere" group="2"/>
                <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0 0 -0.0006" quat="1 0 0 1" mesh="yam_model2"/>
                <geom group="0" type="capsule" size="0.033 0.01" pos="0.0 0.0 0.026" quat="1 0 0 0"/>

                <body name="link_1" pos="0 0 0.0631" quat="1 0 0 1">
                    <inertial pos="-0.00192861 -0.00795735 0.0208176" quat="0.297851 0.642634 0.360045 0.607185"
                        mass="0.12415" diaginertia="0.000180751 0.000145532 5.89179e-05"/>
                    <joint name="joint1" axis="0 0 1" frictionloss="0.1" range="-2.61799 3.05433" armature="0.032"/>
                    <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="5.26159e-07 2.34355e-07 -0.0632" quat="1 0 0 0" mesh="yam_model2__2"/>

                    <body name="link_2" pos="2.5e-05 -0.02 0.0409" quat="1 1 1 1">
                        <inertial pos="0.132008 2.10599e-06 0.000293073" quat="1 1 1 1" mass="1.24434"
                            diaginertia="0.0121902 0.0121318 0.000683304"/>
                        <joint name="joint2" axis="0 0 1" frictionloss="0.1" range="0 3.66519" armature="0.032"/>
                        <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0.0199992 -0.1041 -2.44738e-05" quat="1 -1 -1 -1" mesh="yam_model2__3"/>
                        <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0.0199992 -0.1041 -2.44738e-05" quat="1 -1 -1 -1" mesh="yam_model2__4"/>
                        <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_white" pos="0.0199992 -0.1041 -2.44738e-05" quat="1 -1 -1 -1" mesh="yam_model2__5"/>
                        <geom group="0" type="capsule" size="0.032 0.11" pos="0.13 0 0" quat="1 0 1 0"/>
                        <geom group="0" type="capsule" size="0.033 0.02" pos="0 0.0 0" quat="1 0 0 0"/>
                        <geom group="0" type="capsule" size="0.033 0.025" pos="0.265 0 0" quat="1 0 0 0"/>

                        <body name="link_3" pos="0.264 0 0" quat="0 1 0 0">
                            <inertial pos="-0.121816 -0.054846 -0.000111108" quat="1 1 1 1" mass="0.853698"
                                diaginertia="0.00699732 0.00696112 0.000788244"/>
                            <joint name="joint3" axis="0 0 1" frictionloss="0.1" range="0 3.66519" armature="0.032"/>
                            <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="-0.244001 0.104101 2.44738e-05" quat="1 1 1 -1" mesh="yam_model2__6"/>
                            <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="-0.244001 0.104101 2.44738e-05" quat="1 1 1 -1" mesh="yam_model2__7"/>
                            <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_white" pos="-0.244001 0.104101 2.44738e-05" quat="1 1 1 -1" mesh="yam_model2__8"/>
                            <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="-0.244001 0.104101 2.44738e-05" quat="1 1 1 -1" mesh="yam_model2__9"/>
                            <geom group="0" type="capsule" size="0.034 0.12" pos="-0.14 -0.06 0.0" quat="1 0 1 0"/>
                            <geom group="0" type="capsule" size="0.034 0.015" pos="-0.24 -0.06 0.0" quat="1 0 0 0"/>

                            <body name="link_4" pos="-0.245 -0.06 0" quat="1 0 0 0">
                                <inertial pos="-0.0769778 -0.0527104 0.000154878" quat="0.667 0.667 -0.236 -0.236"
                                    mass="0.463511" diaginertia="0.000791532 0.000744733 0.000282116"/>
                                <joint name="joint4" axis="0 0 1" frictionloss="0.1" range="-1.5708 1.5708" armature="0.0018"/>
                                <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0.00100023 0.164101 2.44738e-05" quat="1 1 1 -1" mesh="yam_model2__10"/>
                                <geom group="0" type="capsule" size="0.03 0.015" pos="-0.073 -0.06 0.0" quat="1 1 0 0"/>

                                <body name="link_5" pos="-0.074 -0.0395 2.5e-05" quat="1 -1 1 1">
                                    <inertial pos="3.64861e-05 0.00025665 0.0353526" quat="1 0 0 0" mass="0.350962"
                                        diaginertia="0.000197802 0.0001775 0.000147402"/>
                                    <joint name="joint5" axis="0 0 1" frictionloss="0.1" range="-1.5708 1.5708" armature="0.0018"/>
                                    <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0 -0.0749971 0.203601" quat="1.32679e-06 1 0 0" mesh="yam_model2__11"/>
                                    <geom group="0" type="capsule" size="0.030 0.015" pos="0 0.025 0.0395" quat="1 1 0 0"/>

                                    <body name="link_6" pos="0 0.0353 0.0395" quat="1 -1 0 0">
                                        <inertial pos="-0.000217767 7.37059e-05 0.0270545" quat="1 1 0 0" mass="0.367476"
                                            diaginertia="0.000265958 0.000242686 0.000227409"/>
                                        <joint name="joint6" axis="0 0 1" frictionloss="0.1" range="-2.0944 2.0944" armature="0.0018"/>
                                        <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0 -0.164101 -0.110597" quat="1 -1 0 0" mesh="yam_model2__12"/>
                                        <geom type="mesh" contype="0" conaffinity="0" density="0" group="1" material="yam_black" pos="0 -0.164101 -0.110597" quat="1 -1 0 0" mesh="yam_model2__13"/>
                                        <geom group="0" type="capsule" size="0.01 0.035" pos="0 0.039 0.052" quat="1 0 1 0"/>
                                        <geom group="0" type="capsule" size="0.030 0.005" pos="0 0.0 0.03" quat="1 0 0 1"/>
                                        <geom group="0" type="capsule" size="0.01 0.035" pos="0 -0.039 0.052" quat="1 0 1 0"/>

                                        <!-- EEF mount body — YamGripper merges here -->
                                        <body name="right_hand" pos="0 0 0.1347" quat="1 0 0 -1">
                                            <!-- Wrist camera (inside right_hand so robocasa's parent_body lookup finds it) -->
                                            <camera name="eye_in_hand" pos="0.05 0 0" quat="0 0.707108 0.707108 0" fovy="75"/>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
</mujoco>
