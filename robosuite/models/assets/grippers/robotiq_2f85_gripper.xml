<mujoco model="robotiq_2f85_gripper">
    <!--
      Robotiq 2F-85 gripper with 4-bar linkage mechanism.
      This gripper is merged into a robot's right_hand body at runtime.
    -->

    <default>
        <default class="2f85">
            <mesh scale="0.001 0.001 0.001"/>
            <general biastype="affine"/>
            <joint axis="1 0 0"/>
            <default class="2f85_driver">
                <joint range="0 0.8" armature="0.005" damping="0.1" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
            </default>
            <default class="2f85_follower">
                <joint range="-0.872664 0.872664" armature="0.001" pos="0 -0.018 0.0065" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
            </default>
            <default class="2f85_spring_link">
                <joint range="-0.29670597283 0.8" armature="0.001" stiffness="0.05" springref="2.62" damping="0.00125"/>
            </default>
            <default class="2f85_coupler">
                <joint range="-1.57 0" armature="0.001" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
            </default>
        </default>
    </default>

    <asset>
        <material name="2f85_metal" rgba="0.58 0.58 0.58 1"/>
        <material name="2f85_silicone" rgba="0.1882 0.1882 0.1882 1"/>
        <material name="2f85_gray" rgba="0.4627 0.4627 0.4627 1"/>
        <material name="2f85_black" rgba="0.149 0.149 0.149 1"/>
        <mesh name="2f85_base" file="meshes/robotiq_2f85/base.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_driver" file="meshes/robotiq_2f85/driver.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_coupler" file="meshes/robotiq_2f85/coupler.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_follower" file="meshes/robotiq_2f85/follower.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_pad" file="meshes/robotiq_2f85/pad.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_silicone_pad" file="meshes/robotiq_2f85/silicone_pad.stl" scale="0.001 0.001 0.001"/>
        <mesh name="2f85_spring_link" file="meshes/robotiq_2f85/spring_link.stl" scale="0.001 0.001 0.001"/>
    </asset>

    <contact>
        <exclude body1="2f85_base" body2="left_driver"/>
        <exclude body1="2f85_base" body2="right_driver"/>
        <exclude body1="2f85_base" body2="left_spring_link"/>
        <exclude body1="2f85_base" body2="right_spring_link"/>
        <exclude body1="right_coupler" body2="right_follower"/>
        <exclude body1="left_coupler" body2="left_follower"/>
    </contact>

    <tendon>
        <fixed name="split">
            <joint joint="right_driver_joint" coef="0.5"/>
            <joint joint="left_driver_joint" coef="0.5"/>
        </fixed>
    </tendon>

    <equality>
        <connect anchor="0 0 0" body1="right_follower" body2="right_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <connect anchor="0 0 0" body1="left_follower" body2="left_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
        <joint joint1="right_driver_joint" joint2="left_driver_joint" polycoef="0 1 0 0 0" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    </equality>

    <actuator>
        <general name="fingers_actuator" tendon="split" forcerange="-5 5" ctrlrange="0 255"
            gainprm="0.3137255 0 0" biasprm="0 -100 -10" biastype="affine"/>
    </actuator>

    <worldbody>
        <body name="2f85_base" pos="0 0 0" childclass="2f85">
            <inertial mass="0.777441" pos="0 -2.70394e-05 0.0354675" quat="1 -0.00152849 0 0"
                diaginertia="0.000260285 0.000225381 0.000152708"/>
            <site name="ft_frame" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 1" type="sphere" group="1"/>

            <!-- EEF site for grip control -->
            <body name="eef" pos="0 0 0.145" quat="0.707105 0 0 -0.707105">
                <site name="grip_site" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 0.5" type="sphere" group="1"/>
                <site name="ee_x" pos="0.1 0 0" size="0.005 .1" quat="0.707105 0 0.707108 0" rgba="1 0 0 0" type="cylinder" group="1"/>
                <site name="ee_y" pos="0 0.1 0" size="0.005 .1" quat="0.707105 0.707108 0 0" rgba="0 1 0 0" type="cylinder" group="1"/>
                <site name="ee_z" pos="0 0 0.1" size="0.005 .1" quat="1 0 0 0" rgba="0 0 1 0" type="cylinder" group="1"/>
                <site name="grip_site_cylinder" pos="0 0 0" size="0.005 10" rgba="0 1 0 0.3" type="cylinder" group="1"/>
            </body>

            <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_base" material="2f85_black" name="2f85_base_visual"/>
            <geom type="mesh" group="0" mesh="2f85_base" name="2f85_base_collision"/>

            <!-- Right-hand side 4-bar linkage -->
            <body name="right_driver" pos="0 0.0306011 0.054904">
                <inertial mass="0.00899563" pos="2.96931e-12 0.0177547 0.00107314"
                    quat="0.681301 0.732003 0 0" diaginertia="1.72352e-06 1.60906e-06 3.22006e-07"/>
                <joint name="right_driver_joint" class="2f85_driver"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_driver" material="2f85_gray" name="right_driver_visual"/>
                <geom type="mesh" group="0" mesh="2f85_driver" name="right_driver_collision"/>
                <body name="right_coupler" pos="0 0.0315 -0.0041">
                    <inertial mass="0.0140974" pos="0 0.00301209 0.0232175"
                        quat="0.705636 -0.0455904 0.0455904 0.705636"
                        diaginertia="4.16206e-06 3.52216e-06 8.88131e-07"/>
                    <joint name="right_coupler_joint" class="2f85_coupler"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_coupler" material="2f85_black" name="right_coupler_visual"/>
                    <geom type="mesh" group="0" mesh="2f85_coupler" name="right_coupler_collision"/>
                </body>
            </body>
            <body name="right_spring_link" pos="0 0.0132 0.0609">
                <inertial mass="0.0221642" pos="-8.65005e-09 0.0181624 0.0212658"
                    quat="0.663403 -0.244737 0.244737 0.663403"
                    diaginertia="8.96853e-06 6.71733e-06 2.63931e-06"/>
                <joint name="right_spring_link_joint" class="2f85_spring_link"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_spring_link" material="2f85_black" name="right_spring_link_visual"/>
                <geom type="mesh" group="0" mesh="2f85_spring_link" name="right_spring_link_collision"/>
                <body name="right_follower" pos="0 0.055 0.0375">
                    <inertial mass="0.0125222" pos="0 -0.011046 0.0124786" quat="1 0.1664 0 0"
                        diaginertia="2.67415e-06 2.4559e-06 6.02031e-07"/>
                    <joint name="right_follower_joint" class="2f85_follower"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_follower" material="2f85_black" name="right_follower_visual"/>
                    <geom type="mesh" group="0" mesh="2f85_follower" name="right_follower_collision"/>
                    <body name="right_pad" pos="0 -0.0189 0.01352">
                        <geom mass="0" type="box" pos="0 -0.0026 0.028125" size="0.011 0.004 0.009375" friction="0.7"
                            solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.55 0.55 0.55 1" group="0" name="right_pad1"/>
                        <geom mass="0" type="box" pos="0 -0.0026 0.009375" size="0.011 0.004 0.009375" friction="0.6"
                            solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.45 0.45 0.45 1" group="0" name="right_pad2"/>
                        <inertial mass="0.0035" pos="0 -0.0025 0.0185" quat="0.707107 0 0 0.707107"
                            diaginertia="4.73958e-07 3.64583e-07 1.23958e-07"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_pad" name="right_pad_visual"/>
                        <body name="right_silicone_pad">
                            <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_silicone_pad" material="2f85_black" name="right_silicone_pad_visual"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- Left-hand side 4-bar linkage -->
            <body name="left_driver" pos="0 -0.0306011 0.054904" quat="0 0 0 1">
                <inertial mass="0.00899563" pos="0 0.0177547 0.00107314" quat="0.681301 0.732003 0 0"
                    diaginertia="1.72352e-06 1.60906e-06 3.22006e-07"/>
                <joint name="left_driver_joint" class="2f85_driver"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_driver" material="2f85_gray" name="left_driver_visual"/>
                <geom type="mesh" group="0" mesh="2f85_driver" name="left_driver_collision"/>
                <body name="left_coupler" pos="0 0.0315 -0.0041">
                    <inertial mass="0.0140974" pos="0 0.00301209 0.0232175"
                        quat="0.705636 -0.0455904 0.0455904 0.705636"
                        diaginertia="4.16206e-06 3.52216e-06 8.88131e-07"/>
                    <joint name="left_coupler_joint" class="2f85_coupler"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_coupler" material="2f85_black" name="left_coupler_visual"/>
                    <geom type="mesh" group="0" mesh="2f85_coupler" name="left_coupler_collision"/>
                </body>
            </body>
            <body name="left_spring_link" pos="0 -0.0132 0.0609" quat="0 0 0 1">
                <inertial mass="0.0221642" pos="-8.65005e-09 0.0181624 0.0212658"
                    quat="0.663403 -0.244737 0.244737 0.663403"
                    diaginertia="8.96853e-06 6.71733e-06 2.63931e-06"/>
                <joint name="left_spring_link_joint" class="2f85_spring_link"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_spring_link" material="2f85_black" name="left_spring_link_visual"/>
                <geom type="mesh" group="0" mesh="2f85_spring_link" name="left_spring_link_collision"/>
                <body name="left_follower" pos="0 0.055 0.0375">
                    <inertial mass="0.0125222" pos="0 -0.011046 0.0124786" quat="1 0.1664 0 0"
                        diaginertia="2.67415e-06 2.4559e-06 6.02031e-07"/>
                    <joint name="left_follower_joint" class="2f85_follower"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_follower" material="2f85_black" name="left_follower_visual"/>
                    <geom type="mesh" group="0" mesh="2f85_follower" name="left_follower_collision"/>
                    <body name="left_pad" pos="0 -0.0189 0.01352">
                        <geom mass="0" type="box" pos="0 -0.0026 0.028125" size="0.011 0.004 0.009375" friction="0.7"
                            solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.55 0.55 0.55 1" group="0" name="left_pad1"/>
                        <geom mass="0" type="box" pos="0 -0.0026 0.009375" size="0.011 0.004 0.009375" friction="0.6"
                            solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.45 0.45 0.45 1" group="0" name="left_pad2"/>
                        <inertial mass="0.0035" pos="0 -0.0025 0.0185" quat="1 0 0 1"
                            diaginertia="4.73958e-07 3.64583e-07 1.23958e-07"/>
                        <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_pad" name="left_pad_visual"/>
                        <body name="left_silicone_pad">
                            <geom type="mesh" contype="0" conaffinity="0" group="1" mesh="2f85_silicone_pad" material="2f85_black" name="left_silicone_pad_visual"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <sensor>
        <force name="force_ee" site="ft_frame"/>
        <torque name="torque_ee" site="ft_frame"/>
    </sensor>
</mujoco>
